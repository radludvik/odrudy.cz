# AntiAgeLab — konfigurace pro Apache (sdílený PHP hosting)
# Web je statický; tento soubor jen zajišťuje správné kódování, HTTPS,
# 404 stránku, kompresi a kešování. Nic dalšího není potřeba nastavovat.

AddDefaultCharset utf-8

# Správné MIME typy pro moderní formáty obrázků
<IfModule mod_mime.c>
  AddType image/webp .webp
  AddType image/avif .avif
  AddType image/svg+xml .svg
</IfModule>

# Přesměrování na HTTPS (funguje na běžných sdílených hostinzích)
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteCond %{HTTPS} !=on
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
</IfModule>

# Vlastní 404 stránka
ErrorDocument 404 /404.html

# Komprese textových souborů
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml
</IfModule>

# Kešování: obrázky a assety dlouho, HTML krátce (aby se změny projevily hned)
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/webp  "access plus 30 days"
  ExpiresByType image/avif  "access plus 30 days"
  ExpiresByType image/jpeg  "access plus 30 days"
  ExpiresByType image/png   "access plus 30 days"
  ExpiresByType image/svg+xml "access plus 30 days"
  ExpiresByType text/css    "access plus 7 days"
  ExpiresByType application/javascript "access plus 7 days"
  ExpiresByType text/html   "access plus 0 seconds"
</IfModule>
